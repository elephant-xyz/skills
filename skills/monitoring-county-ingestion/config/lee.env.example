# Example county monitoring config (Lee County values, account-specific parts redacted).
# Discover real values from CloudFormation stack outputs and:
#   aws lambda list-event-source-mappings --function-name <fn>
#   aws cloudformation describe-stacks --stack-name elephant-oracle-node
#   aws cloudformation describe-stacks --stack-name elephant-permit-harvest

COUNTY_KEY=lee

APPRAISAL_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account>/elephant-oracle-node-prepare-queue-lee
APPRAISAL_QUEUE_NAME=elephant-oracle-node-prepare-queue-lee
# Optional; falls back to the first mapping on APPRAISAL_FUNCTION_NAME
APPRAISAL_EVENT_SOURCE_UUID=
APPRAISAL_FUNCTION_NAME=<elephant-oracle-node-DownloaderFunction-...>

PERMIT_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account>/elephant-oracle-node-property-first-permit-queue
PERMIT_QUEUE_NAME=elephant-oracle-node-property-first-permit-queue
PERMIT_DLQ_URL=https://sqs.<region>.amazonaws.com/<account>/<elephant-permit-harvest-PermitHarvestDeadLetterQueue-...>
PERMIT_FUNCTION_NAME=<elephant-permit-harvest-PermitHarvestWorkerFunctio-...>

# Permit artifacts. PERMIT_JOB_PREFIX supplies the bucket and fallback prefix.
# The status script auto-detects the latest active property-first seed job under
# PERMIT_JOB_ROOT; pass --job-id to force a specific run.
PERMIT_JOB_PREFIX=s3://<env-bucket>/permit-harvest/lee-property-first-seed/<job-id>
# Alternative when no fallback prefix should be used:
# PERMIT_ARTIFACT_BUCKET=<env-bucket>
PERMIT_JOB_ROOT=permit-harvest/lee-property-first-seed/

# Optional Sunbiz transform summary
SUNBIZ_SUMMARY_S3_URI=s3://<env-bucket>/permit-harvest/<sunbiz-job>/lexicon-transform/business-registration-v1/summary.json

# Optional whole-run progress (used by whole-run-progress.sh)
# Feeder checkpoint the permit-harvest worker writes, and the seed CSV data-row count.
FEEDER_STATE_S3_URI=s3://<env-bucket>/permit-harvest/<jobId>/feeder-state.json
SEED_TOTAL_ROWS=516848
